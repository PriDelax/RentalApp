<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rentalapp.Controller.RegisterController"
            prefHeight="600.0" prefWidth="400.0"
            styleClass="root-pane">
    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <VBox alignment="CENTER" spacing="15.0" styleClass="form-container">
            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
            </padding>
            <Label text="📝 Регистрация" styleClass="title-label">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>
            <Separator prefWidth="200.0"/>
            <Label text="Выберите роль:" styleClass="form-label"/>
            <HBox alignment="CENTER" spacing="20.0">
                <RadioButton fx:id="tenantRadio" text="Съёмщик" selected="true"/>
                <RadioButton fx:id="landlordRadio" text="Арендодатель"/>
            </HBox>
            <TextField fx:id="loginField" promptText="Логин (мин. 3 символа)" styleClass="text-field"/>
            <Label fx:id="loginError" textFill="RED" styleClass="field-error" visible="false"/>
            <PasswordField fx:id="passwordField" promptText="Пароль (мин. 6 символов)" styleClass="password-field"/>
            <Label fx:id="passwordError" textFill="RED" styleClass="field-error" visible="false"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Подтвердите пароль" styleClass="password-field"/>
            <Label fx:id="confirmPasswordError" textFill="RED" styleClass="field-error" visible="false"/>
            <TextField fx:id="fullNameField" promptText="ФИО" styleClass="text-field"/>
            <Label fx:id="fullNameError" textFill="RED" styleClass="field-error" visible="false"/>
            <TextField fx:id="phoneField" promptText="Телефон (+7...)" styleClass="text-field"/>
            <Label fx:id="phoneError" textFill="RED" styleClass="field-error" visible="false"/>
            <TextField fx:id="emailField" promptText="Email" styleClass="text-field"/>
            <Label fx:id="emailError" textFill="RED" styleClass="field-error" visible="false"/>
            <TextField fx:id="passportField" promptText="Паспортные данные" styleClass="text-field"/>
            <Label fx:id="passportError" textFill="RED" styleClass="field-error" visible="false"/>
            <VBox fx:id="paymentDetailsBox" spacing="5.0" visible="false" managed="false">
                <TextField fx:id="paymentDetailsField" promptText="Платёжные реквизиты" styleClass="text-field"/>
                <Label fx:id="paymentDetailsError" textFill="RED" styleClass="field-error" visible="false"/>
            </VBox>
            <Label fx:id="generalError" textFill="RED" styleClass="error-label" visible="false" wrapText="true"/>
            <HBox alignment="CENTER" spacing="10.0">
                <Button text="Зарегистрироваться" onAction="#handleRegister" styleClass="button-primary" prefWidth="180.0"/>
                <Button text="Назад" onAction="#handleBack" styleClass="button-back" prefWidth="100.0"/>
            </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>