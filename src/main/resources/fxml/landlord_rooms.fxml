<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rentalapp.Controller.RoomManagementController"
            prefHeight="600.0" prefWidth="900.0">

    <VBox spacing="15.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label text="📋Список помещений" styleClass="page-title">
                <font>
                    <Font name="System Bold" size="20.0"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="➕Добавить помещение" onAction="#addRoom"
                    styleClass="button-primary, button-add"/>
        </HBox>

        <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS"
                   styleClass="data-table">
            <columns>
                <TableColumn text="Адрес" fx:id="addressColumn" prefWidth="250.0"/>
                <TableColumn text="Описание" fx:id="descriptionColumn" prefWidth="200.0"/>
                <TableColumn text="Тип" fx:id="typeColumn" prefWidth="120.0"/>
                <TableColumn text="Комнат" fx:id="roomsNumberColumn" prefWidth="80.0"/>
                <TableColumn text="Площадь" fx:id="squareColumn" prefWidth="80.0"/>
                <TableColumn text="Статус" fx:id="statusColumn" prefWidth="100.0"/>
                <TableColumn text="Действия" fx:id="actionsColumn" prefWidth="120.0"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Обновить" onAction="#handleUpdate" styleClass="button-refresh"/>
            <Button text="Редактировать" onAction="#handleEdit" styleClass="button-edit"/>
            <Button text="Удалить выбранное" onAction="#handleDelete" styleClass="button-danger"/>
        </HBox>

    </VBox>
</AnchorPane>