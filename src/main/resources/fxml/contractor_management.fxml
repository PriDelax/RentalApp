<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.ContractorsManagementController"
      spacing="15.0"
      prefHeight="800.0" prefWidth="1200.0">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Исполнители" styleClass="page-title">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕Добавить исполнителя" onAction="#handleAddContractor" styleClass="button-add"/>
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Поиск:" styleClass="filter-label"/>
        <TextField fx:id="searchField" promptText="Поиск по ФИО или специальности"
                   prefWidth="300.0" onKeyTyped="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Обновить" onAction="#handleRefresh" styleClass="button-refresh"/>
    </HBox>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="contractorsFlowPane" hgap="15.0" vgap="15.0" prefWrapLength="1100.0">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
        </FlowPane>
    </ScrollPane>
</VBox>