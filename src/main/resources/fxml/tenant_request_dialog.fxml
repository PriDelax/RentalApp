<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.TenantRequestDialogController"
      spacing="15.0" prefWidth="500.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="Новая заявка на ремонт" styleClass="dialog-title"/>
    <GridPane hgap="10.0" vgap="10.0">
        <Label text="Категория:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="categoryCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300.0"/>
        <Label text="Приоритет:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="priorityCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="300.0"/>
        <Label text="Описание проблемы:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextArea fx:id="descriptionArea" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="300.0" prefHeight="100.0" wrapText="true"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Отмена" onAction="#handleCancel" styleClass="button-secondary"/>
        <Button text="Создать" onAction="#handleCreate" styleClass="button-primary"/>
    </HBox>

</VBox>