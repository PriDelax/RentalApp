<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.ContractorDialogController"
      spacing="15.0" prefWidth="500.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <Label fx:id="dialogTitle" text="Новый исполнитель" styleClass="dialog-title">
        <font>
            <Font name="System Bold" size="20.0"/>
        </font>
    </Label>
    <GridPane hgap="10.0" vgap="10.0">
        <Label text="ФИО:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fullNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   prefWidth="300.0" promptText="Например: Петров Пётр Петрович"/>
        <Label text="Телефон:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   prefWidth="300.0" promptText="+7 (999) 123-45-67"/>
        <Label text="Специальность:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="specialityField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   prefWidth="300.0" promptText="Например: Сантехник"/>
        <Label text="Опыт (лет):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Spinner fx:id="experienceSpinner" GridPane.rowIndex="3" GridPane.columnIndex="1"
                 prefWidth="300.0"/>
        <Label text="Рейтинг:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Spinner fx:id="ratingSpinner" GridPane.rowIndex="4" GridPane.columnIndex="1"
                 prefWidth="300.0"/>
        <Label text="Описание:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextArea fx:id="descriptionArea" GridPane.rowIndex="5" GridPane.columnIndex="1"
                  prefWidth="300.0" prefHeight="80.0" wrapText="true"/>
    </GridPane>
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Отмена" onAction="#handleCancel" styleClass="button-secondary"/>
        <Button fx:id="saveButton" text="Создать" onAction="#handleSave" styleClass="button-primary"/>
    </HBox>
</VBox>