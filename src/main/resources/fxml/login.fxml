<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rentalapp.Controller.LoginController"
            prefHeight="400.0" prefWidth="350.0"
            styleClass="root-pane">

    <VBox alignment="CENTER" spacing="20.0"
          AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>
        <Label text="Учёт аренды"
               styleClass="title-label">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Label>
        <Label text="жилых помещений"
               styleClass="subtitle-label">
            <font>
                <Font name="System Bold" size="24.0"/>
            </font>
        </Label>
        <Separator prefWidth="200.0"/>
        <TextField fx:id="loginField"
                   promptText="Логин"
                   styleClass="text-field"/>
        <PasswordField fx:id="passwordField"
                       promptText="Пароль"
                       styleClass="password-field"/>
        <Label fx:id="errorLabel"
               textFill="RED"
               visible="false"
               styleClass="error-label"/>
        <Button text="Войти"
                onAction="#handleLogin"
                styleClass="button-primary"
                prefWidth="250.0"/>
        <Hyperlink fx:id="registerLink"
                   text="Впервые? Зарегистрируйтесь"
                   onAction="#handleRegister"
                   styleClass="hyperlink-style"/>
    </VBox>
</AnchorPane>