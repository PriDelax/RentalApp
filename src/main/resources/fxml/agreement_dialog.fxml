<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.AgreementDialogController"
      spacing="15.0" prefWidth="500.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <Label text="📄Новый договор" styleClass="dialog-title"/>
    <GridPane hgap="10.0" vgap="10.0">
        <Label text="Помещение:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="roomCombo" GridPane.rowIndex="0" GridPane.columnIndex="1"
                  prefWidth="300.0" promptText="Выберите свободное помещение"/>
        <Label text="Съёмщик:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="tenantCombo" GridPane.rowIndex="1" GridPane.columnIndex="1"
                  prefWidth="300.0" promptText="Выберите съёмщика"/>
        <Label text="Дата начала:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="startDatePicker" GridPane.rowIndex="2" GridPane.columnIndex="1"
                    prefWidth="300.0"/>
        <Label text="Дата окончания:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <DatePicker fx:id="endDatePicker" GridPane.rowIndex="3" GridPane.columnIndex="1"
                    prefWidth="300.0"/>
        <Label text="Арендная плата (₽):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="arendaSumField" GridPane.rowIndex="4" GridPane.columnIndex="1"
                   prefWidth="300.0" promptText="Например: 30000"/>
        <Label text="График платежей:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <ComboBox fx:id="paymentScheduleCombo" GridPane.rowIndex="5" GridPane.columnIndex="1"
                  prefWidth="300.0"/>
    </GridPane>
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Отмена" onAction="#handleCancel" styleClass="button-secondary"/>
        <Button fx:id="saveButton" text="Создать" onAction="#handleCreate" styleClass="button-primary"/>
    </HBox>
</VBox>