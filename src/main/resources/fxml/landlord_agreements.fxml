<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.AgreementsManagementController"
      spacing="10.0"
      prefHeight="600.0" prefWidth="900.0">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="🗒️Договоры" styleClass="page-title">
            <font>
                <Font name="System Bold" size="20.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕Новый договор" onAction="#handleCreateAgreement"
                styleClass="button-add"/>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>
    <VBox styleClass="stat-widget" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
        <Label fx:id="totalAgreementsLabel" text="0" styleClass="stat-value"/>
        <Label text="Всего договоров" styleClass="stat-label"/>
    </VBox>

    <VBox styleClass="stat-widget active" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
        <Label fx:id="activeAgreementsLabel" text="0" styleClass="stat-value"/>
        <Label text="Активных" styleClass="stat-label"/>
    </VBox>

    <VBox styleClass="stat-widget income" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
        <Label fx:id="totalIncomeLabel" text="0 ₽" styleClass="stat-value"/>
        <Label text="Доход / месяц" styleClass="stat-label"/>
    </VBox>

    <VBox styleClass="stat-widget expiring" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
        <Label fx:id="expiringSoonLabel" text="0" styleClass="stat-value"/>
        <Label text="Истекают скоро" styleClass="stat-label"/>
    </VBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Фильтры:" styleClass="filter-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Все" onAction="#filterAll" styleClass="button-filter"/>
        <Button text="Действующие" onAction="#filterActive" styleClass="button-filter"/>
        <Button text="Расторгнутые" onAction="#filterTerminate" styleClass="button-filter"/>
    </HBox>

    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS">
        <Tab text="📋Список договоров" closable="false">
            <AnchorPane>
                <TableView fx:id="agreementsTable" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                           AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" styleClass="data-table">
                    <columns>
                        <TableColumn text="Съёмщик" fx:id="tenantColumn" prefWidth="150.0"/>
                        <TableColumn text="Помещение" fx:id="roomColumn" prefWidth="150.0"/>
                        <TableColumn text="Арендодатель" fx:id="landlordColumn" prefWidth="150.0"/>
                        <TableColumn text="Дата создания" fx:id="effectiveDateColumn" prefWidth="120.0"/>
                        <TableColumn text="Дата расторжения" fx:id="determinationDateColumn" prefWidth="120.0"/>
                        <TableColumn text="Арендная плата" fx:id="arendaSumColumn" prefWidth="250.0"/>
                        <TableColumn text="График платежей" fx:id="paymentScheduleColumn" prefWidth="120.0"/>
                        <TableColumn text="Статус" fx:id="statusColumn" prefWidth="100.0"/>
                        <TableColumn text="Действия" fx:id="actionsColumn" prefWidth="150.0"/>
                    </columns>
                </TableView>
            </AnchorPane>
        </Tab>
        <Tab text="Статистика" closable="false">
            <VBox spacing="15.0">
                <padding>
                    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                </padding>
                <Label text="Аналитика договоров" styleClass="page-title">
                    <font>
                        <Font name="System Bold" size="20.0"/>
                    </font>
                </Label>
                <HBox spacing="20.0">
                    <VBox styleClass="chart-container" alignment="CENTER" prefWidth="400.0">
                        <Label text=" Распределение по статусам" styleClass="chart-title"/>
                        <PieChart fx:id="statusPieChart" prefWidth="380.0" prefHeight="350.0"/>
                    </VBox>
                    <VBox styleClass="chart-container" alignment="CENTER" prefWidth="400.0">
                        <Label text=" Доходы по помещениям" styleClass="chart-title"/>
                        <BarChart fx:id="incomeBarChart" prefWidth="380.0" prefHeight="350.0">
                            <xAxis>
                                <CategoryAxis label="Помещение"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Сумма (₽)"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_RIGHT">
                    <Button text="Обновить данные" onAction="#updateCharts" styleClass="button-refresh"/>
                </HBox>
            </VBox>
        </Tab>
        <Tab text="Календарь платежей" closable="false">
            <fx:include source="payments_calendar.fxml"/>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Обновить" onAction="#handleUpdate" styleClass="button-refresh"/>
        <Button text="Редактировать" onAction="#handleEdit" styleClass="button-edit"/>
    </HBox>
</VBox>