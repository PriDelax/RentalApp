<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.TenantPaymentsController"
      spacing="15.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="Мои платежи" styleClass="page-title">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <HBox spacing="10.0" alignment="CENTER">
        <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
        </padding>
        <VBox styleClass="stat-widget paid" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
            <Label fx:id="paidAmountLabel" text="0 ₽" styleClass="stat-value"/>
            <Label text="Оплачено" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-widget pending" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
            <Label fx:id="pendingAmountLabel" text="0 ₽" styleClass="stat-value"/>
            <Label text="Ожидается" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-widget partial" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
            <Label fx:id="partialAmountLabel" text="0 ₽" styleClass="stat-value"/>
            <Label text="Частично" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-widget total" alignment="CENTER" prefWidth="200.0" prefHeight="100.0">
            <Label fx:id="totalAmountLabel" text="0 ₽" styleClass="stat-value"/>
            <Label text="Всего" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Фильтр по статусу:" styleClass="filter-label"/>
        <ComboBox fx:id="statusFilterCombo" prefWidth="200.0">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Все"/>
                    <String fx:value="оплачено"/>
                    <String fx:value="не оплачено"/>
                    <String fx:value="частично"/>
                </FXCollections>
            </items>
        </ComboBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Обновить" onAction="#handleRefresh" styleClass="button-refresh"/>
    </HBox>

    <TableView fx:id="paymentsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="Дата платежа" fx:id="dateColumn" prefWidth="120.0"/>
            <TableColumn text="Помещение" fx:id="roomColumn" prefWidth="250.0"/>
            <TableColumn text="Сумма" fx:id="amountColumn" prefWidth="120.0"/>
            <TableColumn text="Тип" fx:id="typeColumn" prefWidth="120.0"/>
            <TableColumn text="Статус" fx:id="statusColumn" prefWidth="120.0"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="10.0" styleClass="info-banner">
        <Label text="ℹ️ Платежи отображаются только в режиме просмотра. Для оплаты обратитесь к арендодателю."
               styleClass="info-text"/>
    </HBox>

</VBox>