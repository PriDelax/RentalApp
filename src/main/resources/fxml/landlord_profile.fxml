<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.LandlordProfileController"
      spacing="20.0">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <Label text="Мой профиль" styleClass="page-title">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <GridPane hgap="15.0" vgap="15.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        <Label text="ФИО:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="fullNameField" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   prefWidth="400.0" styleClass="readonly-field"/>
        <Label text="Телефон:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   prefWidth="400.0" promptText="+7 (999) 123-45-67"/>
        <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   prefWidth="400.0" promptText="example@mail.ru"/>
        <Label text="Паспорт:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="passportField" editable="false" GridPane.rowIndex="3" GridPane.columnIndex="1"
                   prefWidth="400.0" styleClass="readonly-field"/>
        <Label text="Реквизиты для оплаты:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="paymentDetailsField" GridPane.rowIndex="4" GridPane.columnIndex="1"
                   prefWidth="400.0" promptText="Сбербанк 4276 1234 5678 9012"/>
        <Label text="Дата рождения:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="birthDateField" editable="false" GridPane.rowIndex="5" GridPane.columnIndex="1"
                   prefWidth="400.0" styleClass="readonly-field"/>
        <Label text="Зарегистрирован:" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="createdAtField" editable="false" GridPane.rowIndex="6" GridPane.columnIndex="1"
                   prefWidth="400.0" styleClass="readonly-field"/>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="💾Сохранить изменения" onAction="#handleSave" styleClass="button-primary"/>
        <Button text="🔑Сменить пароль" onAction="#handleChangePassword" styleClass="button-secondary"/>
    </HBox>
</VBox>