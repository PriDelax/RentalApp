<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.TenantAgreementsController"
      spacing="15.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="📄Мои договоры" styleClass="page-title">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <TableView fx:id="agreementsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="Помещение" fx:id="roomColumn" prefWidth="250.0"/>
            <TableColumn text="Арендодатель" fx:id="landlordColumn" prefWidth="200.0"/>
            <TableColumn text="Дата начала" fx:id="startDateColumn" prefWidth="120.0"/>
            <TableColumn text="Дата окончания" fx:id="endDateColumn" prefWidth="120.0"/>
            <TableColumn text="Арендная плата" fx:id="rentColumn" prefWidth="120.0"/>
            <TableColumn text="График платежей" fx:id="scheduleColumn" prefWidth="150.0"/>
            <TableColumn text="Статус" fx:id="statusColumn" prefWidth="120.0"/>
        </columns>
    </TableView>
    <HBox alignment="CENTER" spacing="10.0" styleClass="info-banner">
        <Label text="ℹ️ Договоры отображаются только в режиме просмотра. Для внесения изменений обратитесь к арендодателю."
               styleClass="info-text" wrapText="true"/>
    </HBox>

</VBox>