<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rentalapp.Controller.TenantMainController"
            prefHeight="800.0" prefWidth="1200.0">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
            <padding>
                <Insets top="15.0" right="20.0" bottom="15.0" left="20.0"/>
            </padding>
            <Label text="Панель съёмщика" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="tenantNameLabel" text="Имя съёмщика" styleClass="user-name"/>
            <Button text="🚪Выход" onAction="#handleLogout" styleClass="button-logout"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5.0" styleClass="sidebar" prefWidth="200.0">
            <padding>
                <Insets top="20.0" right="10.0" bottom="20.0" left="10.0"/>
            </padding>
            <Button text="Главная" onAction="#showDashboard" styleClass="menu-button"/>
            <Button text="Мои договоры" onAction="#showAgreements" styleClass="menu-button"/>
            <Button text="Заявки на ремонт" onAction="#showRequests" styleClass="menu-button"/>
            <Button text="Мои платежи" onAction="#showPayments" styleClass="menu-button"/>
            <Button text=" Профиль" onAction="#showProfile" styleClass="menu-button"/>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
        </StackPane>
    </center>
</BorderPane>