<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="rentalapp.Controller.RequestsManagementController"
      spacing="10.0"
      prefHeight="600.0" prefWidth="900.0">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="🗒️Заявки на ремонт" styleClass="page-title">
            <font>
                <Font name="System Bold" size="20.0"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕Новая заявка" onAction="#handleCreateRequest"
                styleClass="button-add"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Фильтры:" styleClass="filter-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Все" onAction="#filterAll" styleClass="button-filter"/>
        <Button text="Новые" onAction="#filterNew" styleClass="button-filter"/>
        <Button text="В работе" onAction="#filterWorking" styleClass="button-filter"/>
        <Button text="Завершённые" onAction="#filterDone" styleClass="button-filter"/>
    </HBox>

    <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="Описание" fx:id="descriptionColumn" prefWidth="250.0"/>
            <TableColumn text="Категория" fx:id="categoryColumn" prefWidth="120.0"/>
            <TableColumn text="Приоритет" fx:id="priorityColumn" prefWidth="100.0"/>
            <TableColumn text="Статус" fx:id="currentStatusColumn" prefWidth="100.0"/>
            <TableColumn text="Помещение" fx:id="roomColumn" prefWidth="150.0"/>
            <TableColumn text="Съёмщик" fx:id="tenantColumn" prefWidth="150.0"/>
            <TableColumn text="Исполнитель" fx:id="contractorColumn" prefWidth="150.0"/>
            <TableColumn text="Дата создания" fx:id="createdAtColumn" prefWidth="120.0"/>
            <TableColumn text="Действия" fx:id="actionsColumn" prefWidth="150.0"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Обновить" onAction="#handleUpdate" styleClass="button-refresh"/>
        <Button text="Редактировать" onAction="#handleEdit" styleClass="button-edit"/>
        <Button text="Удалить" onAction="#handleDelete" styleClass="button-danger"/>
    </HBox>

</VBox>